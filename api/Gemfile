source "https://rubygems.org"

ruby "3.3.0"

gem "rails", "~> 8.0.4"
gem "pg", "~> 1.1"
gem "puma", ">= 5.0"

gem "tzinfo-data", platforms: %i[ windows jruby ]

# Rails 8 defaults — DB-backed adapters (no Redis needed)
gem "solid_cache"
gem "solid_queue"
gem "solid_cable"

gem "bootsnap", require: false

# Auth
gem "clerk-sdk-ruby", require: "clerk"

# Serializers
gem "blueprinter"

# CORS
gem "rack-cors"

# Rate limiting
gem "rack-attack"

# AI
gem "anthropic"
gem "connection_pool", "~> 2.5"  # pin to avoid Ruby 3.3 syntax error in 3.0.x

# pgvector
gem "pgvector"
gem "neighbor"

# HTTP client (Voyage AI embeddings)
gem "faraday", "~> 2.9"
gem "faraday-retry", "~> 2.2"

# Deployment helpers (keep for Dockerfile)
gem "kamal", require: false
gem "thruster", require: false

group :development, :test do
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"
  gem "brakeman", require: false
  gem "rubocop-rails-omakase", require: false
  gem "rspec-rails"
  gem "webmock"
  gem "timecop"
end

group :test do
  gem "shoulda-matchers"
end
